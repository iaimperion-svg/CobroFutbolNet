<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CobroFutbol</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
            background: #0a0a0f;
            color: #f2f2f7;
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            -webkit-font-smoothing: antialiased;
            margin: 0;
        }

        /* ─── NAVBAR ─── */
        .cf-navbar {
            background: rgba(10, 10, 18, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.07);
            padding: 0;
            height: 56px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .cf-navbar .container {
            height: 56px;
            display: flex;
            align-items: center;
        }

        /* ─── LOGO ─── */
        .cf-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none !important;
        }

        .cf-logo-box {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: linear-gradient(145deg, #059669, #064e3b);
            border: 1px solid rgba(52,211,153,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .cf-brand-name {
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: #f2f2f7;
            line-height: 1;
            display: block;
        }

        .cf-brand-name em {
            font-style: normal;
            color: #34d399;
        }

        .cf-brand-sub {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #636366;
            display: block;
            margin-top: 1px;
        }

        /* ─── TOGGLER ─── */
        .cf-toggler {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            color: #aeaeb2;
            padding: 6px 10px;
            line-height: 1;
            cursor: pointer;
        }

        .cf-toggler:hover {
            background: rgba(255,255,255,0.1);
        }

        /* ─── NAV LINKS ─── */
        .cf-nav-link {
            font-size: 0.83rem;
            font-weight: 600;
            color: #aeaeb2 !important;
            padding: 6px 14px !important;
            border-radius: 8px;
            transition: background 0.15s, color 0.15s;
        }

        .cf-nav-link:hover {
            color: #f2f2f7 !important;
            background: rgba(255,255,255,0.06);
        }

        .cf-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(52,211,153,0.08);
            border: 1px solid rgba(52,211,153,0.2);
            border-radius: 999px;
            padding: 4px 12px 4px 8px;
            font-size: 0.72rem;
            font-weight: 600;
            color: #34d399;
        }

        .cf-status-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #34d399;
            flex-shrink: 0;
            animation: blink 2s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.3; }
        }

        /* ─── MAIN / FOOTER ─── */
        main {
            padding-top: 20px;
        }

        .cf-footer {
            margin-top: 60px;
            padding: 18px;
            text-align: center;
            color: #636366;
            font-size: 0.75rem;
            letter-spacing: 0.04em;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        .cf-footer em {
            font-style: normal;
            color: #34d399;
        }

        /* ─── SCROLLBAR ─── */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #070710; }
        ::-webkit-scrollbar-thumb { background: #064e3b; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #059669; }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg cf-navbar">
        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand cf-brand" asp-controller="Dashboard" asp-action="Index">
                <div class="cf-logo-box">
                    <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="16" cy="16" r="12" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
                        <polygon points="16,7 20.7,10.5 18.9,16 13.1,16 11.3,10.5" fill="white"/>
                        <line x1="16"    y1="7"    x2="16"    y2="3"    stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                        <line x1="20.7"  y1="10.5" x2="24"    y2="8"    stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                        <line x1="18.9"  y1="16"   x2="23"    y2="17.5" stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                        <line x1="13.1"  y1="16"   x2="9"     y2="17.5" stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                        <line x1="11.3"  y1="10.5" x2="8"     y2="8"    stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                    </svg>
                </div>
                <div>
                    <span class="cf-brand-name">Cobro<em>Fútbol</em></span>
                    <span class="cf-brand-sub">Gestión de pagos</span>
                </div>
            </a>

            <!-- TOGGLER MOBILE -->
            <button class="cf-toggler navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="3" y1="6"  x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <!-- LINKS -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item">
                        <a class="nav-link cf-nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item ms-2">
                        <span class="cf-status">
                            <span class="cf-status-dot"></span>
                            En línea
                        </span>
                    </li>
                </ul>
            </div>

        </div>
    </nav>

    <main role="main" class="container">
        @RenderBody()
    </main>

    <footer class="cf-footer">
        &copy; @DateTime.Now.Year <em>CobroFútbol</em> &mdash; Gestión deportiva inteligente
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
